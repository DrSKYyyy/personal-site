---
import { siteConfig } from '../data/siteData';
---

<div id="typing-intro" class="typing-intro">
  <div class="typing-bg"></div>
  <div class="typing-content">
    <div class="typing-lines" id="typing-lines"></div>
    <div class="typing-subtitle" id="typing-subtitle">我追风，也等你</div>
    <div class="typing-hint" id="typing-hint">点击任意位置跳过</div>
  </div>
  <div id="typing-data" style="display:none">{JSON.stringify({
    lines: siteConfig.intro.lines,
    subtitle: siteConfig.intro.subtitle,
    typingSpeed: siteConfig.intro.typingSpeed,
    eraseSpeed: siteConfig.intro.eraseSpeed,
    pauseAfterType: siteConfig.intro.pauseAfterType,
    pauseBeforeNext: siteConfig.intro.pauseBeforeNext,
  })}</div>
</div>

<script is:inline>
  (function() {
    var intro = document.getElementById('typing-intro');
    var container = document.getElementById('typing-lines');
    var hint = document.getElementById('typing-hint');
    var subtitleEl = document.getElementById('typing-subtitle');

    if (!intro) return;

    var skip = false;

    var cfg = {};
    try {
      var dataEl = document.getElementById('typing-data');
      if (dataEl && dataEl.textContent) cfg = JSON.parse(dataEl.textContent);
    } catch(e) {}
    cfg.lines = cfg.lines || [];
    cfg.typingSpeed = cfg.typingSpeed || 80;
    cfg.eraseSpeed = cfg.eraseSpeed || 40;
    cfg.pauseAfterType = cfg.pauseAfterType || 1500;
    cfg.pauseBeforeNext = cfg.pauseBeforeNext || 500;

    function dismiss() {
      if (!intro) return;
      intro.classList.add('fade-out');
      setTimeout(function() {
        intro.style.display = 'none';
        document.body.style.overflow = '';
      }, 600);
    }

    function startTyping() {
      if (cfg.lines.length < 2) { dismiss(); return; }

      var line1 = cfg.lines[0];
      var line2 = cfg.lines[1];
      var p = document.createElement('p');
      p.className = 'typing-line';
      container.appendChild(p);

      function typeForward(text, callback) {
        var i = 0;
        function step() {
          if (skip) { dismiss(); return; }
          if (i <= text.length) {
            p.textContent = text.substring(0, i);
            i++;
            setTimeout(step, cfg.typingSpeed);
          } else {
            p.textContent = text;
            p.classList.add('done');
            if (callback) setTimeout(callback, cfg.pauseAfterType);
          }
        }
        step();
      }

      function eraseBackward(text, callback) {
        var i = text.length;
        function step() {
          if (skip) { dismiss(); return; }
          if (i >= 0) {
            p.textContent = text.substring(0, i);
            i--;
            setTimeout(step, cfg.eraseSpeed);
          } else {
            p.textContent = '';
            if (callback) setTimeout(callback, cfg.pauseBeforeNext);
          }
        }
        step();
      }

      typeForward(line1, function() {
        eraseBackward(line1, function() {
          typeForward(line2, function() {
            setTimeout(dismiss, cfg.pauseAfterType);
          });
        });
      });
    }

    intro.addEventListener('click', function() {
      skip = true;
      dismiss();
    });

    var navEntries = performance.getEntriesByType('navigation');
    if (navEntries.length > 0 && navEntries[0].type === 'reload') {
      sessionStorage.removeItem('intro_shown');
    }

    var shown = sessionStorage.getItem('intro_shown');
    if (!shown) {
      sessionStorage.setItem('intro_shown', '1');
      intro.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      setTimeout(function() {
        if (subtitleEl) subtitleEl.classList.add('visible');
        startTyping();
      }, 200);

      setTimeout(function() {
        if (hint) hint.style.opacity = '1';
      }, 3000);
    } else {
      intro.style.display = 'none';
    }
  })();
</script>

<style>
  .typing-intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    animation: introFadeIn 0.8s ease forwards;
  }

  .typing-intro.fade-out {
    animation: introFadeOut 0.6s ease forwards;
  }

  @keyframes introFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes introFadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  .typing-bg {
    position: absolute;
    inset: 0;
    background: #FFFFFF;
  }

  .typing-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
    max-width: 800px;
  }

  .typing-lines {
    min-height: 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .typing-line {
    font-family: var(--font-heading);
    font-size: 3.2rem;
    color: #2C3E50;
    line-height: 1.4;
    opacity: 1;
    min-height: 1.4em;
  }

  .typing-line:last-child:not(.done)::after {
    content: '|';
    color: #5DADE2;
    font-weight: 700;
    animation: cursorPulse 0.6s ease-in-out infinite;
    margin-left: 2px;
  }

  @keyframes cursorPulse {
    0%, 100% { opacity: 1; transform: scaleY(1); }
    50% { opacity: 0.2; transform: scaleY(0.6); }
  }

  .typing-subtitle {
    margin-top: 1.5rem;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: #999;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .typing-subtitle.visible {
    opacity: 1;
  }

  .typing-hint {
    margin-top: 3rem;
    font-size: 0.85rem;
    color: #ccc;
    opacity: 0;
    transition: opacity 0.8s ease;
    animation: hintBounce 2s ease-in-out infinite;
  }

  @keyframes hintBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  @media (max-width: 768px) {
    .typing-line {
      font-size: 2rem;
    }

    .typing-subtitle {
      font-size: 0.95rem;
    }
  }
</style>
