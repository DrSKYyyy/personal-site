---
import { siteConfig } from '../data/siteData';

export interface SearchResult {
  title: string;
  url: string;
  description: string;
  date: string;
  tags: string[];
  body: string;
}

const { posts = [] } = Astro.props as { posts?: any[] };

const base = siteConfig.base;

const searchData: SearchResult[] = posts.map((post: any) => ({
  title: post.data?.title || post.title || '',
  url: (post.slug ? base + '/writing/' + post.slug : ''),
  description: post.data?.description || post.description || '',
  date: post.data?.date || post.date || '',
  tags: post.data?.tags || post.tags || [],
  body: post.body || '',
})).filter(p => p.title && p.url);
---

<div class="search-bar-container" id="search-bar-container">
  <div class="search-bar-inner" id="search-bar-inner">
    <svg class="search-bar-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input type="text" id="search-input" class="search-input" placeholder="搜索文章..." autocomplete="off" />
    <button class="search-close-btn" id="search-close-btn" aria-label="关闭搜索">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <div id="search-dropdown" class="search-dropdown"></div>
  <div id="search-data" style="display:none">{JSON.stringify(searchData)}</div>
</div>

<script is:inline>
  (function() {
    var container = document.getElementById('search-bar-container');
    var inner = document.getElementById('search-bar-inner');
    var input = document.getElementById('search-input');
    var dropdown = document.getElementById('search-dropdown');
    var closeBtn = document.getElementById('search-close-btn');

    var postsData = [];
    try {
      var searchDataEl = document.getElementById('search-data');
      if (searchDataEl && searchDataEl.textContent && searchDataEl.textContent !== '[]') {
        postsData = JSON.parse(searchDataEl.textContent);
      }
    } catch(e) { postsData = []; }

    var isOpen = false;

    function openSearch() {
      if (isOpen) return;
      isOpen = true;
      container.classList.add('active');
      inner.classList.add('active');
      dropdown.innerHTML = '';
      setTimeout(function() { if (input) { input.value = ''; input.focus(); } }, 200);
    }

    function closeSearch() {
      if (!isOpen) return;
      isOpen = false;
      container.classList.remove('active');
      inner.classList.remove('active');
      dropdown.innerHTML = '';
      if (input) input.value = '';
    }

    inner.addEventListener('click', function(e) {
      if (!isOpen) openSearch();
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        closeSearch();
      });
    }

    document.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        if (isOpen) closeSearch();
        else openSearch();
      }
      if (e.key === 'Escape' && isOpen) {
        closeSearch();
      }
    });

    document.addEventListener('click', function(e) {
      if (isOpen && container && !container.contains(e.target)) {
        closeSearch();
      }
    });

    if (input) {
      input.addEventListener('input', function() {
        var q = input.value.trim().toLowerCase();
        if (!q) {
          dropdown.innerHTML = '';
          return;
        }

        var filtered = postsData.filter(function(p) {
          return (p.title && p.title.toLowerCase().includes(q)) ||
                 (p.description && p.description.toLowerCase().includes(q)) ||
                 (p.tags && p.tags.some(function(t) { return t.toLowerCase().includes(q); })) ||
                 (p.body && p.body.toLowerCase().includes(q));
        });

        if (filtered.length === 0) {
          dropdown.innerHTML = '<div class="sd-empty">未找到与 "<strong>' + input.value + '</strong>" 相关的内容</div>';
          return;
        }

        dropdown.innerHTML = filtered.map(function(p) {
          var tagsHtml = '';
          if (p.tags && p.tags.length > 0) {
            tagsHtml = p.tags.map(function(t) { return '<span class="sd-tag">#' + t + '</span>'; }).join('');
          }
          var sentence = findSentenceInBody(p.body, q);
          var sentenceHtml = sentence
            ? '<div class="sd-item-sentence">' + highlightMatch(sentence, q) + '</div>'
            : (p.description
              ? '<div class="sd-item-sentence">' + highlightMatch(p.description, q) + '</div>'
              : '');
          return '<a href="' + p.url + '" class="sd-item">' +
            '<div class="sd-item-title">' + highlightMatch(p.title, q) + '</div>' +
            '<div class="sd-item-meta">' + p.date + ' ' + tagsHtml + '</div>' +
            sentenceHtml +
            '</a>';
        }).join('');
      });
    }

    function findSentenceInBody(body, query) {
      if (!body || !query) return '';
      var plainText = body
        .replace(/```[\s\S]*?```/g, '')
        .replace(/!\[([^\]]*)\]\([^)]*\)/g, '')
        .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
        .replace(/[#*`~>_|-]{2,}/g, ' ')
        .replace(/\n{3,}/g, '\n\n')
        .replace(/\s+/g, ' ')
        .trim();
      var idx = plainText.toLowerCase().indexOf(query);
      if (idx === -1) return '';
      var punctBefore = /[。！？\n]/;
      var start = idx;
      while (start > 0) {
        start--;
        if (punctBefore.test(plainText[start])) {
          start++;
          break;
        }
      }
      if (start < 0) start = 0;
      var punctAfter = /[。！？\n]/;
      var end = idx + query.length;
      while (end < plainText.length) {
        if (punctAfter.test(plainText[end])) {
          end++;
          break;
        }
        end++;
      }
      if (end > plainText.length) end = plainText.length;
      var sentence = plainText.substring(start, end).trim();
      var maxLen = 160;
      if (sentence.length > maxLen) {
        var kwIdx = sentence.toLowerCase().indexOf(query);
        var halfLen = Math.floor(maxLen / 2);
        var sStart = Math.max(0, kwIdx - halfLen);
        var sEnd = Math.min(sentence.length, kwIdx + query.length + halfLen);
        sentence = (sStart > 0 ? '...' : '') + sentence.substring(sStart, sEnd) + (sEnd < sentence.length ? '...' : '');
      }
      return sentence;
    }

    function highlightMatch(text, query) {
      if (!query) return text;
      var regex = new RegExp('(' + query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
      return text.replace(regex, '<strong>$1</strong>');
    }
  })();
</script>

<style>
  .search-bar-container {
    position: relative;
  }

  .search-bar-inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: 999px;
    padding: 0 0.75rem;
    height: 36px;
    width: 36px;
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    box-sizing: border-box;
  }

  .search-bar-inner.active {
    width: 260px;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(93,173,226,0.12), var(--shadow-sm);
    cursor: text;
  }

  .search-bar-icon {
    flex-shrink: 0;
    color: var(--color-text-secondary);
    min-width: 16px;
  }

  .search-bar-inner.active .search-bar-icon {
    color: var(--color-primary);
  }

  .search-input {
    border: none;
    outline: none;
    background: transparent;
    font-size: 0.88rem;
    font-family: var(--font-body);
    color: var(--color-text);
    width: 0;
    opacity: 0;
    transition: all 0.25s ease 0.1s;
    padding: 0;
    flex: 1;
  }

  .search-bar-inner.active .search-input {
    width: auto;
    opacity: 1;
  }

  .search-input::placeholder {
    color: var(--color-text-secondary);
  }

  .search-close-btn {
    display: none;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    padding: 0.2rem;
    border-radius: 50%;
    transition: all 0.15s ease;
    flex-shrink: 0;
    line-height: 1;
  }

  .search-close-btn:hover {
    color: var(--color-text);
    background: var(--color-bg);
  }

  .search-bar-inner.active .search-close-btn {
    display: flex;
  }

  .search-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    width: 420px;
    max-height: 420px;
    overflow-y: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    z-index: 200;
    opacity: 0;
    transform: translateY(-8px) scale(0.96);
    transition: all 0.2s ease;
    pointer-events: none;
    transform-origin: top right;
  }

  .search-bar-container.active .search-dropdown {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .sd-empty {
    padding: 1.5rem 1rem;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
  }

  .sd-item {
    display: block;
    padding: 0.85rem 1rem;
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.15s ease;
    border-left: 3px solid transparent;
    border-bottom: 1px solid var(--color-border);
  }

  .sd-item:last-child {
    border-bottom: none;
  }

  .sd-item:hover {
    background: var(--color-bg);
    border-left-color: var(--color-primary);
  }

  .sd-item-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    margin-bottom: 0.15rem;
    line-height: 1.4;
  }

  .sd-item-title strong {
    color: var(--color-primary);
  }

  .sd-item-meta {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }

  .sd-tag {
    font-size: 0.72rem;
    color: var(--color-primary);
  }

  .sd-item-sentence {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    padding: 0.5rem 0.65rem;
    background: var(--color-bg);
    border-radius: var(--radius-sm);
    margin-top: 0.3rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .sd-item-sentence strong {
    color: var(--color-primary);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .search-dropdown {
      width: calc(100vw - 2rem);
      right: -1rem;
      max-height: 50vh;
    }
  }
</style>
