---
export interface SearchResult {
  title: string;
  url: string;
  description: string;
  date: string;
  tags: string[];
}

const { posts = [] } = Astro.props as { posts?: any[] };

const base = '/personal-site';

const searchData: SearchResult[] = posts.map((post: any) => ({
  title: post.data?.title || post.title || '',
  url: (post.slug ? base + '/writing/' + post.slug : ''),
  description: post.data?.description || post.description || '',
  date: post.data?.date || post.date || '',
  tags: post.data?.tags || post.tags || [],
})).filter(p => p.title && p.url);
---

<script id="search-data" type="application/json">{JSON.stringify(searchData)}</script>

<dialog id="search-dialog" class="search-dialog">
  <div class="search-overlay" data-close></div>
  <div class="search-panel">
    <div class="search-header">
      <span class="search-icon">🔍</span>
      <input
        type="text"
        id="search-input"
        class="search-input"
        placeholder="搜索文章标题、描述或标签..."
        autocomplete="off"
      />
      <button class="search-close" data-close aria-label="关闭搜索">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div id="search-results" class="search-results">
      <div class="search-hint">输入关键词开始搜索...</div>
    </div>
  </div>
</dialog>

<script is:inline>
  (function() {
    if (document.getElementById('search-dialog')) {
      var dialog = document.getElementById('search-dialog');
      var input = document.getElementById('search-input');
      var results = document.getElementById('search-results');
      var openBtn = document.getElementById('search-open');

      var postsData = [];
      try {
        var searchDataEl = document.getElementById('search-data');
        if (searchDataEl && searchDataEl.textContent) {
          postsData = JSON.parse(searchDataEl.textContent);
        }
      } catch (e) {
        postsData = [];
      }

      function openSearch() {
        if (!dialog) return;
        dialog.style.display = 'flex';
        setTimeout(function() { dialog.classList.add('visible'); }, 10);
        if (input) {
          input.value = '';
          setTimeout(function() { input.focus(); }, 150);
        }
        if (results) {
          results.innerHTML = '<div class="search-hint">输入关键词开始搜索...</div>';
        }
      }

      function closeSearch() {
        if (!dialog) return;
        dialog.classList.remove('visible');
        setTimeout(function() { dialog.style.display = 'none'; }, 200);
      }

      if (openBtn) {
        openBtn.addEventListener('click', openSearch);
      }

      if (dialog) {
        dialog.addEventListener('click', function(e) {
          if (e.target.hasAttribute('data-close')) closeSearch();
        });
      }

      document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          openSearch();
        }
        if (e.key === 'Escape' && dialog && dialog.style.display === 'flex') {
          closeSearch();
        }
      });

      if (input) {
        input.addEventListener('input', function() {
          var q = input.value.trim().toLowerCase();
          if (!q) {
            results.innerHTML = '<div class="search-hint">输入关键词开始搜索...</div>';
            return;
          }

          var filtered = postsData.filter(function(p) {
            return (p.title && p.title.toLowerCase().includes(q)) ||
                   (p.description && p.description.toLowerCase().includes(q)) ||
                   (p.tags && p.tags.some(function(t) { return t.toLowerCase().includes(q); }));
          });

          if (filtered.length === 0) {
            results.innerHTML = '<div class="search-no-results">未找到与 "<strong>' + input.value + '</strong>" 相关的内容</div>';
            return;
          }

          results.innerHTML = filtered.map(function(p) {
            var tagsHtml = '';
            if (p.tags && p.tags.length > 0) {
              tagsHtml = '· ' + p.tags.map(function(t) { return '#' + t; }).join(' ');
            }
            return '<a href="' + p.url + '" class="search-result-item">' +
              '<div class="result-title">' + p.title + '</div>' +
              '<div class="result-meta">' + p.date + ' ' + tagsHtml + '</div>' +
              '<div class="result-desc">' + (p.description || '') + '</div>' +
              '</a>';
          }).join('');
        });
      }
    }
  })();
</script>

<style>
  .search-dialog {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: transparent;
    border: none;
    display: none;
    padding: 0;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
    opacity: 0;
  }

  .search-dialog.visible {
    opacity: 1;
  }

  .search-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }

  .search-panel {
    position: relative;
    width: 90%;
    max-width: 560px;
    margin: 0 auto;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    animation: slideDown 0.25s ease;
  }

  @keyframes slideDown {
    from { transform: translateY(-20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .search-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1rem;
    font-family: var(--font-body);
    color: var(--color-text);
    background: transparent;
  }

  .search-input::placeholder {
    color: var(--color-text-secondary);
  }

  .search-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    padding: 0.3rem;
    border-radius: 50%;
    transition: all var(--transition-fast);
    flex-shrink: 0;
  }

  .search-close:hover {
    background: var(--color-bg);
    color: var(--color-text);
  }

  .search-results {
    max-height: 400px;
    overflow-y: auto;
    padding: 0.5rem 0;
  }

  .search-hint {
    padding: 2rem 1.25rem;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }

  .search-result-item {
    display: block;
    padding: 0.75rem 1.25rem;
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--transition-fast);
    border-left: 3px solid transparent;
  }

  .search-result-item:hover {
    background: var(--color-bg);
    border-left-color: var(--color-primary);
  }

  .search-result-item .result-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .search-result-item .result-meta {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .search-result-item .result-desc {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-no-results {
    padding: 2rem 1.25rem;
    text-align: center;
    color: var(--color-text-secondary);
  }
</style>
