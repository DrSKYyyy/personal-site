---
import { siteConfig } from '../data/siteData';
import VisitorCounter from './VisitorCounter.astro';
const base = siteConfig.base;
---

<footer class="footer">
  <div class="container footer-content">
    <div class="footer-brand">
      <a href={base ? base : '/'} class="footer-logo gradient-text">{siteConfig.title}</a>
      <p class="footer-desc">{siteConfig.description}</p>
    </div>

    <div class="footer-social">
      <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <a href={siteConfig.social.csdn} target="_blank" rel="noopener noreferrer" class="social-link social-link-csdn" aria-label="CSDN">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <text x="12" y="17" text-anchor="middle" font-size="18" font-weight="bold" font-family="Arial,sans-serif">C</text>
        </svg>
      </a>
      {siteConfig.social.twitter !== 'https://twitter.com' && (
        <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Twitter">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      )}
      <a href="https://mail.163.com/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="发送邮件到 sunhaotian_game@163.com">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="footer-bottom container">
    <p>© {new Date().getFullYear()} {siteConfig.title}. {siteConfig.footer.copyright}</p>
    <VisitorCounter />
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 0 1.5rem;
    margin-top: 4rem;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    text-decoration: none;
  }

  .footer-desc {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    margin-top: 0.5rem;
    max-width: 300px;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    color: var(--color-text-secondary);
    background: var(--color-bg);
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    color: white;
    background: var(--color-gradient);
    transform: translateY(-3px);
  }

  .footer-bottom {
    text-align: center;
    padding-top: 1.5rem;
    margin-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-size: 0.85rem;
  }
</style>
