---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/siteData';
import TypingIntro from '../components/TypingIntro.astro';
import VisitorMessageForm from '../components/VisitorMessageForm.astro';

const allPosts = await getCollection('blog');
const publicPosts = allPosts.filter(p => p.data.visibility === '公开');
const recentPosts = publicPosts
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date))
  .slice(0, 3);
---

<Layout title="首页">
  <TypingIntro />
  <section class="hero">
    <div class="container hero-content page-enter">
      <div class="hero-text">
        <h1 class="hero-title gradient-text">{siteConfig.slogan}</h1>
        <p class="hero-subtitle">{siteConfig.subSlogan}</p>
        <p class="hero-desc">这是一个有趣的、真诚的人的数字花园。<br/>在这里，我用文字记录成长，用代码表达想法，用生活感受世界。</p>
        <div class="hero-actions">
          <a href="/about" class="btn btn-primary">了解更多 →</a>
          <a href="/writing" class="btn btn-outline">阅读文章</a>
        </div>
      </div>
      <div class="hero-avatar" id="avatar-area">
        <div class="avatar-wrapper">
          <img src="/images/avatar.svg" alt="头像" class="avatar-img" id="avatar-img" />
          <div class="avatar-glow"></div>
        </div>
        <div class="speech-bubble" id="speech-bubble">今天很开心！🎉</div>
      </div>
    </div>

    <div class="scroll-indicator">
      <span>向下滚动</span>
      <div class="scroll-arrow">↓</div>
    </div>
  </section>

  <section class="recent-posts container page-enter">
    <h2 class="section-title">最新文章</h2>
    <div class="posts-grid">
      {recentPosts.map(post => (
        <a href={`/writing/${post.slug}`} class="post-card card">
          <div class="post-card-content">
            <div class="post-date">{post.data.date}</div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-excerpt">{post.data.description || post.data.title}</p>
            {post.data.tags && (
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
    <div class="view-all">
      <a href="/writing" class="btn btn-outline">查看全部文章 →</a>
    </div>
  </section>

  <section class="home-message container page-enter">
    <h2 class="section-title">💌 给我留言</h2>
    <div class="home-message-content">
      <VisitorMessageForm
        title=""
        subtitle="有任何想法、建议或想说的话，都可以在这里告诉我"
        placeholder="写下你想说的话..."
      />
    </div>
  </section>
</Layout>

<script is:inline>
  const avatarArea = document.getElementById('avatar-area');
  const speechBubble = document.getElementById('speech-bubble');
  const messages = ['今天很开心！🎉', '又学到新东西啦！', '加油，少年！💪', '阳光真好 ☀️', '去追风吧！', '嘻嘻 😊', '今天也是元气满满的一天！'];

  avatarArea?.addEventListener('mouseenter', () => {
    speechBubble.classList.add('show');
    speechBubble.textContent = messages[Math.floor(Math.random() * messages.length)];
    setTimeout(() => speechBubble.classList.remove('show'), 3000);
  });
</script>

<style>
  .hero {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  .hero-text {
    flex: 1;
    animation: fadeInUp 0.8s ease forwards;
  }

  .hero-title {
    font-size: 3.5rem;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .hero-subtitle {
    font-size: 1.3rem;
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: 1rem;
    font-family: var(--font-heading);
  }

  .hero-desc {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 500px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-avatar {
    flex-shrink: 0;
    position: relative;
    cursor: pointer;
  }

  .avatar-wrapper {
    position: relative;
    width: 240px;
    height: 240px;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    animation: float 4s ease-in-out infinite;
    transition: transform var(--transition-normal);
    filter: drop-shadow(0 8px 24px rgba(93, 173, 226, 0.2));
  }

  .avatar-wrapper:hover .avatar-img {
    transform: scale(1.05) rotate(-3deg);
  }

  .avatar-glow {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: var(--color-gradient);
    opacity: 0.1;
    filter: blur(20px);
    animation: pulse 3s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.08; transform: scale(1); }
    50% { opacity: 0.15; transform: scale(1.05); }
  }

  .speech-bubble {
    position: absolute;
    top: -10px;
    right: -30px;
    background: var(--color-surface);
    padding: 0.6rem 1.2rem;
    border-radius: var(--radius-xl);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    box-shadow: var(--shadow-md);
    opacity: 0;
    transform: translateY(10px);
    transition: all var(--transition-normal);
    white-space: nowrap;
    border: 2px solid var(--color-secondary);
    z-index: 2;
  }

  .speech-bubble::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 30%;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-top: 10px solid var(--color-surface);
  }

  .speech-bubble.show {
    opacity: 1;
    transform: translateY(0);
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    animation: fadeInUp 1s ease 1s forwards;
    opacity: 0;
  }

  .scroll-arrow {
    font-size: 1.2rem;
    animation: bounce 2s ease infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  .recent-posts {
    padding: 4rem 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .post-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-card-content {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .post-title {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-title {
    color: var(--color-primary);
  }

  .post-excerpt {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex: 1;
  }

  .post-tags {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .view-all {
    text-align: center;
    margin-top: 2.5rem;
  }

  .home-message {
    padding: 3rem 0 4rem;
    max-width: 700px;
  }

  .home-message-content {
    margin-top: -1rem;
  }

  @media (max-width: 768px) {
    .hero-content {
      flex-direction: column-reverse;
      text-align: center;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-desc {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .avatar-wrapper {
      width: 180px;
      height: 180px;
    }

    .speech-bubble {
      right: -10px;
    }
  }
</style>
