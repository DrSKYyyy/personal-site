---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/siteData';
import TypingIntro from '../components/TypingIntro.astro';
import GiscusComments from '../components/GiscusComments.astro';
import VisitorMessageForm from '../components/VisitorMessageForm.astro';

const allPosts = await getCollection('blog');
const publicPosts = allPosts.filter(p => p.data.visibility === '公开');
const recentPosts = publicPosts
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date))
  .slice(0, 3);
const giscusConfigured = siteConfig.giscus.repo !== 'your-username/your-repo';
const base = siteConfig.base;
---

<Layout title="首页">
  <TypingIntro />
  <section class="hero">
    <div class="container hero-content page-enter">
      <div class="hero-text">
        <h1 class="hero-title gradient-text">{siteConfig.slogan}</h1>
        <p class="hero-subtitle">{siteConfig.subSlogan}</p>
        <p class="hero-desc">这是一个有趣的、真诚的人的数字花园。<br/>在这里，我用文字记录成长，用代码表达想法，用生活感受世界。</p>
        <div class="hero-actions">
          <a href={base + '/about'} class="btn btn-primary">了解更多 →</a>
          <a href={base + '/writing'} class="btn btn-outline">阅读文章</a>
        </div>
      </div>
      <div class="hero-avatar" id="avatar-area">
        <div class="avatar-wrapper">
          <img src={base + siteConfig.avatar} alt="头像" class="avatar-img" id="avatar-img" />
          <div class="avatar-glow"></div>
        </div>
        <div class="speech-bubble" id="speech-bubble">今天很开心！🎉</div>
      </div>
    </div>

    <div class="scroll-indicator">
      <span>向下滚动</span>
      <div class="scroll-arrow">↓</div>
    </div>
  </section>

  <section class="recent-posts container page-enter">
    <h2 class="section-title">最新文章</h2>
    <div class="posts-grid">
      {recentPosts.map(post => (
        <a href={base + '/writing/' + post.slug} class="post-card card">
          <div class="post-card-content">
            <div class="post-date">{post.data.date}</div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-excerpt">{post.data.description || post.data.title}</p>
            {post.data.tags && (
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
    <div class="view-all">
      <a href={base + '/writing'} class="btn btn-outline">查看全部文章 →</a>
    </div>
  </section>

  <section class="home-comments container page-enter">
    <h2 class="section-title">💬 留言互动</h2>
    <div class="comments-tabs">
      <button class="comments-tab active" data-tab="discuss-home">💬 公开讨论</button>
      <button class="comments-tab" data-tab="message-home">💌 匿名留言</button>
    </div>

    <div id="comments-tab-discuss-home" class="comments-tab-content active">
      {giscusConfigured ? (
        <GiscusComments />
      ) : (
        <div class="home-comment-placeholder">
          <p>🔧 公开讨论功能正在配置中...</p>
          <p class="placeholder-hint">站长完成 Giscus 配置后即可使用</p>
        </div>
      )}
    </div>

    <div id="comments-tab-message-home" class="comments-tab-content">
      <VisitorMessageForm
        title=""
        subtitle="无需登录，只有站长能看到你的留言"
        placeholder="写下你想说的话..."
      />
    </div>
  </section>
</Layout>

<script is:inline>
  (function() {
    var tabs = document.querySelectorAll('.comments-tab');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        var target = tab.dataset.tab;
        document.querySelectorAll('.comments-tab-content').forEach(function(c) {
          c.classList.remove('active');
        });
        var el = document.getElementById('comments-tab-' + target);
        if (el) el.classList.add('active');
      });
    });
  })();
</script>

<style>
  .home-comments {
    padding: 3rem 0 4rem;
    max-width: 700px;
  }

  .comments-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .comments-tab {
    padding: 0.5rem 1.2rem;
    border-radius: var(--radius-xl);
    border: 2px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: 0.9rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .comments-tab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .comments-tab.active {
    background: var(--color-gradient);
    border-color: transparent;
    color: white;
  }

  .comments-tab-content {
    display: none;
  }

  .comments-tab-content.active {
    display: block;
  }

  .home-comment-placeholder {
    text-align: center;
    padding: 2rem;
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .placeholder-hint {
    font-size: 0.85rem;
    margin-top: 0.5rem;
    opacity: 0.7;
  }
</style>
