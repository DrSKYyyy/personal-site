---
import Layout from '../../layouts/Layout.astro';

const books = [
  { title: '代码大全', author: 'Steve McConnell', status: '在读', rating: '⭐⭐⭐⭐', note: '软件构建的百科全书' },
  { title: '人类简史', author: '尤瓦尔·赫拉利', status: '已读', rating: '⭐⭐⭐⭐⭐', note: '从宏观视角看人类文明' },
  { title: '设计模式', author: 'GoF', status: '已读', rating: '⭐⭐⭐⭐', note: '面向对象设计的经典之作' },
  { title: '深入理解计算机系统', author: 'Randal E. Bryant', status: '在读', rating: '⭐⭐⭐⭐⭐', note: '理解计算机的底层运作' },
  { title: '百年孤独', author: '加西亚·马尔克斯', status: '想读', rating: '', note: '魔幻现实主义的巅峰' },
  { title: '活着', author: '余华', status: '已读', rating: '⭐⭐⭐⭐⭐', note: '人是为了活着本身而活着' },
];

const fitnessData = [
  { label: '跑步', current: 120, target: 200, unit: '公里' },
  { label: '俯卧撑', current: 45, target: 100, unit: '天' },
  { label: '引体向上', current: 30, target: 50, unit: '天' },
  { label: '深蹲', current: 35, target: 80, unit: '天' },
];

const travelSpots = [
  { name: '北京', lat: 39.9042, lng: 116.4074, emoji: '🏛️', desc: '故宫看雪' },
  { name: '上海', lat: 31.2304, lng: 121.4737, emoji: '🌆', desc: '外滩夜景' },
  { name: '杭州', lat: 30.2741, lng: 120.1551, emoji: '🌊', desc: '西湖泛舟' },
  { name: '成都', lat: 30.5728, lng: 104.0668, emoji: '🐼', desc: '看大熊猫' },
  { name: '西安', lat: 34.3416, lng: 108.9398, emoji: '🏯', desc: '兵马俑' },
];
---

<Layout title="特别">
  <section class="special-page container page-enter">
    <h1 class="section-title">🌟 特别角落</h1>

    <section class="special-section">
      <h2 class="special-section-title">📚 读书角落</h2>
      <p class="special-section-desc">正在读、读过、想读的好书</p>
      <div class="books-grid">
        {books.map(book => (
          <div class="book-card card">
            <div class="book-rating">{book.rating || '📖'}</div>
            <h3 class="book-title">{book.title}</h3>
            <p class="book-author">{book.author}</p>
            <div class="book-status" data-status={book.status}>
              {book.status === '已读' ? '✅' : book.status === '在读' ? '📖' : '🎯'} {book.status}
            </div>
            <p class="book-note">{book.note}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="special-section">
      <h2 class="special-section-title">💪 健身日志</h2>
      <p class="special-section-desc">持续进步，成为更好的自己</p>
      <div class="fitness-grid">
        {fitnessData.map(item => {
          const pct = Math.min(Math.round((item.current / item.target) * 100), 100);
          return (
            <div class="fitness-card card">
              <div class="fitness-header">
                <h3>{item.label}</h3>
                <span class="fitness-count">{item.current}/{item.target} {item.unit}</span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill" style={`width: ${pct}%`}></div>
              </div>
              <div class="progress-label">{pct}%</div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="special-section">
      <h2 class="special-section-title">🗺️ 旅行足迹</h2>
      <p class="special-section-desc">用脚步丈量世界</p>
      <div class="travel-map card">
        <div class="map-placeholder">
          <div class="map-content">
            {travelSpots.map(spot => (
              <div class="travel-spot">
                <span class="spot-emoji">{spot.emoji}</span>
                <div class="spot-info">
                  <strong>{spot.name}</strong>
                  <span>{spot.desc}</span>
                </div>
              </div>
            ))}
          </div>
          <div class="map-decoration">
            <svg viewBox="0 0 400 200" xmlns="http://www.w3.org/2000/svg">
              <path d="M50 150 Q100 50 150 120 Q200 30 250 100 Q300 60 350 130" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-dasharray="6,4" opacity="0.5"/>
              <circle cx="50" cy="150" r="5" fill="var(--color-primary)"/>
              <circle cx="150" cy="120" r="5" fill="var(--color-secondary)"/>
              <circle cx="250" cy="100" r="5" fill="var(--color-accent)"/>
              <circle cx="350" cy="130" r="5" fill="var(--color-primary)"/>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <section class="special-section easter-egg-section">
      <h2 class="special-section-title">🎮 彩蛋入口</h2>
      <p class="special-section-desc">在任意页面输入 <strong>"少年"</strong>，看看会发生什么 ✈️</p>
      <div class="egg-hint card">
        <span class="egg-icon">✈️</span>
        <p>提示：试试在键盘上输入 <code>少年</code> 或 <code>sn</code></p>
      </div>
    </section>
  </section>
</Layout>

<style>
  .special-page {
    padding-top: 2rem;
    padding-bottom: 4rem;
    max-width: 900px;
  }

  .special-section {
    margin-bottom: 3.5rem;
  }

  .special-section-title {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .special-section-desc {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.25rem;
  }

  .book-card {
    text-align: center;
  }

  .book-rating {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .book-title {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .book-author {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  .book-status {
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-xl);
    display: inline-block;
    margin-bottom: 0.75rem;
  }

  .book-status[data-status="已读"] { background: #e8f5e9; color: #2e7d32; }
  .book-status[data-status="在读"] { background: #e3f2fd; color: #1565c0; }
  .book-status[data-status="想读"] { background: #fff3e0; color: #e65100; }

  .book-note {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .fitness-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
  }

  .fitness-card h3 {
    font-size: 1rem;
  }

  .fitness-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .fitness-count {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .progress-bar {
    height: 12px;
    background: var(--color-bg);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 0.4rem;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-gradient);
    border-radius: 6px;
    transition: width 1s ease;
    animation: fillBar 1.5s ease forwards;
  }

  @keyframes fillBar {
    from { width: 0; }
  }

  .progress-label {
    text-align: right;
    font-size: 0.8rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .travel-map {
    overflow: hidden;
  }

  .map-placeholder {
    position: relative;
  }

  .map-content {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .travel-spot {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: var(--color-bg);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .travel-spot:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .spot-emoji {
    font-size: 1.5rem;
  }

  .spot-info {
    display: flex;
    flex-direction: column;
  }

  .spot-info strong {
    font-size: 0.9rem;
  }

  .spot-info span {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .map-decoration svg {
    width: 100%;
    height: auto;
  }

  .easter-egg-section .egg-hint {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-align: left;
  }

  .egg-icon {
    font-size: 2rem;
    animation: float 2s ease-in-out infinite;
  }

  .egg-hint p {
    color: var(--color-text-secondary);
  }

  .egg-hint code {
    padding: 0.2rem 0.5rem;
    background: var(--color-bg);
    border-radius: 4px;
    font-family: var(--font-body);
    color: var(--color-primary);
    font-weight: 600;
  }
</style>
