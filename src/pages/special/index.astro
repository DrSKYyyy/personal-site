---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../data/siteData';
const special = siteConfig.special;
---

<Layout title="特别">
  <section class="special-page container page-enter">
    <h1 class="section-title">{special.pageTitle}</h1>

    <section class="special-section">
      <h2 class="special-section-title">{special.books.title}</h2>
      <p class="special-section-desc">{special.books.desc}</p>
      <div class="books-grid">
        {special.books.list.map(book => (
          <div class="book-card card">
            <div class="book-rating">{book.rating || '📖'}</div>
            <h3 class="book-title">{book.title}</h3>
            <p class="book-author">{book.author}</p>
            <div class="book-status" data-status={book.status}>
              {book.status === '已读' ? '✅' : book.status === '在读' ? '📖' : '🎯'} {book.status}
            </div>
            <p class="book-note">{book.note}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="special-section">
      <h2 class="special-section-title">{special.fitness.title}</h2>
      <p class="special-section-desc">{special.fitness.desc}</p>
      <div class="fitness-grid">
        {special.fitness.items.map(item => {
          const pct = Math.min(Math.round((item.current / item.target) * 100), 100);
          return (
            <div class="fitness-card card">
              <div class="fitness-header">
                <h3>{item.label}</h3>
                <span class="fitness-count">{item.current}/{item.target} {item.unit}</span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill" style={`width: ${pct}%`}></div>
              </div>
              <div class="progress-label">{pct}%</div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="special-section">
      <h2 class="special-section-title">{special.travel.title}</h2>
      <p class="special-section-desc">{special.travel.desc}</p>
      <div class="travel-map card">
        <div class="map-placeholder">
          <div class="map-content">
            {special.travel.spots.map(spot => (
              <div class="travel-spot">
                <span class="spot-emoji">{spot.emoji}</span>
                <div class="spot-info">
                  <strong>{spot.name}</strong>
                  <span>{spot.desc}</span>
                </div>
              </div>
            ))}
          </div>
          <div class="map-decoration">
            <svg viewBox="0 0 400 200" xmlns="http://www.w3.org/2000/svg">
              <path d="M50 150 Q100 50 150 120 Q200 30 250 100 Q300 60 350 130" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-dasharray="6,4" opacity="0.5"/>
              <circle cx="50" cy="150" r="5" fill="var(--color-primary)"/>
              <circle cx="150" cy="120" r="5" fill="var(--color-secondary)"/>
              <circle cx="250" cy="100" r="5" fill="var(--color-accent)"/>
              <circle cx="350" cy="130" r="5" fill="var(--color-primary)"/>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <section class="special-section easter-egg-section">
      <h2 class="special-section-title">{special.easterEgg.title}</h2>
      <p class="special-section-desc" set:html={special.easterEgg.desc}></p>
      <div class="egg-hint card">
        <span class="egg-icon">✈️</span>
        <p set:html={special.easterEgg.hint}></p>
      </div>
    </section>
  </section>
</Layout>

<style>
  .special-page {
    padding-top: 2rem;
    padding-bottom: 4rem;
    max-width: 900px;
  }

  .special-section {
    margin-bottom: 3.5rem;
  }

  .special-section-title {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .special-section-desc {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.25rem;
  }

  .book-card {
    text-align: center;
  }

  .book-rating {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .book-title {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .book-author {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  .book-status {
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-xl);
    display: inline-block;
    margin-bottom: 0.75rem;
  }

  .book-status[data-status="已读"] { background: #e8f5e9; color: #2e7d32; }
  .book-status[data-status="在读"] { background: #e3f2fd; color: #1565c0; }
  .book-status[data-status="想读"] { background: #fff3e0; color: #e65100; }

  .book-note {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .fitness-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
  }

  .fitness-card h3 {
    font-size: 1rem;
  }

  .fitness-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .fitness-count {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .progress-bar {
    height: 12px;
    background: var(--color-bg);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 0.4rem;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-gradient);
    border-radius: 6px;
    transition: width 1s ease;
    animation: fillBar 1.5s ease forwards;
  }

  @keyframes fillBar {
    from { width: 0; }
  }

  .progress-label {
    text-align: right;
    font-size: 0.8rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .travel-map {
    overflow: hidden;
  }

  .map-placeholder {
    position: relative;
  }

  .map-content {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .travel-spot {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: var(--color-bg);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .travel-spot:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .spot-emoji {
    font-size: 1.5rem;
  }

  .spot-info {
    display: flex;
    flex-direction: column;
  }

  .spot-info strong {
    font-size: 0.9rem;
  }

  .spot-info span {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .map-decoration svg {
    width: 100%;
    height: auto;
  }

  .easter-egg-section .egg-hint {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-align: left;
  }

  .egg-icon {
    font-size: 2rem;
    animation: float 2s ease-in-out infinite;
  }

  .egg-hint p {
    color: var(--color-text-secondary);
  }

  .egg-hint code {
    padding: 0.2rem 0.5rem;
    background: var(--color-bg);
    border-radius: 4px;
    font-family: var(--font-body);
    color: var(--color-primary);
    font-weight: 600;
  }
</style>
