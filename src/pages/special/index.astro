---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../data/siteData';
const special = siteConfig.special;
const bookList = special.books.list.filter(b => b.title);
const previewCount = special.books.maxPreview || 6;
const hasMore = bookList.length > previewCount;
---

<Layout title="特别">
  <section class="special-page container page-enter">
    <h1 class="section-title">{special.pageTitle}</h1>

    <section class="special-section">
      <h2 class="special-section-title">{special.books.title}</h2>
      <p class="special-section-desc">{special.books.desc}</p>
      <div class="books-grid" id="books-preview">
        {bookList.slice(0, previewCount).map(book => (
          <div class="book-card card">
            <div class="book-rating">{book.rating || '📖'}</div>
            <h3 class="book-title">{book.title}</h3>
            <p class="book-author">{book.author}</p>
            <div class="book-status" data-status={book.status}>
              {book.status === '已读' ? '✅' : book.status === '在读' ? '📖' : '🎯'} {book.status}
            </div>
            <p class="book-note">{book.note}</p>
          </div>
        ))}
      </div>

      {hasMore && (
        <div class="books-actions">
          <button id="books-toggle-btn" class="books-toggle-btn">
            <span class="books-toggle-text">📚 查看全部书籍</span>
            <span class="books-toggle-icon">▼</span>
          </button>
        </div>
      )}

      {hasMore && (
        <div class="books-expandable" id="books-expandable">
          <div class="books-scroll-container">
            <div class="books-grid">
              {bookList.slice(previewCount).map(book => (
                <div class="book-card card">
                  <div class="book-rating">{book.rating || '📖'}</div>
                  <h3 class="book-title">{book.title}</h3>
                  <p class="book-author">{book.author}</p>
                  <div class="book-status" data-status={book.status}>
                    {book.status === '已读' ? '✅' : book.status === '在读' ? '📖' : '🎯'} {book.status}
                  </div>
                  <p class="book-note">{book.note}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}
    </section>

    <section class="special-section">
      <h2 class="special-section-title">{special.fitness.title}</h2>
      <p class="special-section-desc">{special.fitness.desc}</p>
      <div class="fitness-grid">
        {special.fitness.items.map(item => {
          const pct = Math.min(Math.round((item.current / item.target) * 100), 100);
          return (
            <div class="fitness-card card">
              <div class="fitness-header">
                <h3>{item.label}</h3>
                <span class="fitness-count">{item.current}/{item.target} {item.unit}</span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill" style={`width: ${pct}%`}></div>
              </div>
              <div class="progress-label">{pct}%</div>
            </div>
          );
        })}
      </div>
    </section>



    <section class="special-section easter-egg-section">
      <h2 class="special-section-title">{special.easterEgg.title}</h2>
      <p class="special-section-desc" set:html={special.easterEgg.desc}></p>
      <div class="egg-hint card">
        <span class="egg-icon">✈️</span>
        <p set:html={special.easterEgg.hint}></p>
      </div>
    </section>
  </section>
</Layout>

<script is:inline>
  (function() {
    var btn = document.getElementById('books-toggle-btn');
    var expandable = document.getElementById('books-expandable');
    if (btn && expandable) {
      btn.addEventListener('click', function() {
        var isOpen = expandable.classList.toggle('open');
        btn.querySelector('.books-toggle-text').textContent = isOpen ? '📚 收起书籍列表' : '📚 查看全部书籍';
        btn.querySelector('.books-toggle-icon').textContent = isOpen ? '▲' : '▼';
      });
    }
  })();
</script>

<style>
  .special-page {
    padding-top: 2rem;
    padding-bottom: 4rem;
    max-width: 900px;
  }

  .special-section {
    margin-bottom: 3.5rem;
  }

  .special-section-title {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .special-section-desc {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.25rem;
  }

  .book-card {
    text-align: center;
  }

  .book-rating {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .book-title {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .book-author {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  .book-status {
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-xl);
    display: inline-block;
    margin-bottom: 0.75rem;
  }

  .book-status[data-status="已读"] { background: #e8f5e9; color: #2e7d32; }
  .book-status[data-status="在读"] { background: #e3f2fd; color: #1565c0; }
  .book-status[data-status="想读"] { background: #fff3e0; color: #e65100; }

  .book-note {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .books-actions {
    text-align: center;
    margin-top: 0.75rem;
  }

  .books-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.2rem;
    background: var(--color-bg);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-xl);
    cursor: pointer;
    font-family: var(--font-heading);
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    transition: all var(--transition-fast);
  }

  .books-toggle-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: 0 2px 10px rgba(93, 173, 226, 0.12);
  }

  .books-toggle-icon {
    font-size: 0.75rem;
    transition: transform var(--transition-fast);
  }

  .books-expandable {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease;
  }

  .books-expandable.open {
    max-height: 1000px;
  }

  .books-scroll-container {
    max-height: 560px;
    overflow-y: auto;
    padding: 1rem 0 0.5rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary) var(--color-border);
  }

  .books-scroll-container::-webkit-scrollbar {
    width: 6px;
  }

  .books-scroll-container::-webkit-scrollbar-track {
    background: var(--color-border);
    border-radius: 3px;
  }

  .books-scroll-container::-webkit-scrollbar-thumb {
    background: var(--color-primary);
    border-radius: 3px;
  }

  .fitness-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
  }

  .fitness-card h3 {
    font-size: 1rem;
  }

  .fitness-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .fitness-count {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .progress-bar {
    height: 12px;
    background: var(--color-bg);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 0.4rem;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-gradient);
    border-radius: 6px;
    transition: width 1s ease;
    animation: fillBar 1.5s ease forwards;
  }

  @keyframes fillBar {
    from { width: 0; }
  }

  .progress-label {
    text-align: right;
    font-size: 0.8rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .easter-egg-section .egg-hint {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-align: left;
  }

  .egg-icon {
    font-size: 2rem;
    animation: float 2s ease-in-out infinite;
  }

  .egg-hint p {
    color: var(--color-text-secondary);
  }

  .egg-hint code {
    padding: 0.2rem 0.5rem;
    background: var(--color-bg);
    border-radius: 4px;
    font-family: var(--font-body);
    color: var(--color-primary);
    font-weight: 600;
  }
</style>
